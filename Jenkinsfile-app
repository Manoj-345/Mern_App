pipeline {
    agent any

    environment {
        IMAGE_TAG = "${env.BUILD_NUMBER}"

        IMAGE_BACKEND  = "manoj232005/quickchat-server:${IMAGE_TAG}"
        IMAGE_FRONTEND = "manoj232005/quickchat-client:${IMAGE_TAG}"
        IMAGE_AIOPS    = "manoj232005/quickchat-aiops:${IMAGE_TAG}"

        PROMETHEUS_URL = "http://13.206.91.169:9090"
        CPU_THRESHOLD  = "70"
        MAX_REPLICAS   = "5"
        DEPLOYMENT_NAME = "quickchat-backend"
        NAMESPACE = "default"
        ASG_NAME = "quickchat-worker-asg"
        AWS_REGION = "ap-south-1"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        timeout(time: 40, unit: 'MINUTES')
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Manoj-345/Mern_App.git',
                    credentialsId: 'github-creds'
            }
        }

        stage('Build Images') {
            parallel {
                stage('Backend') {
                    steps { sh 'docker build -t $IMAGE_BACKEND ./server' }
                }
                stage('Frontend') {
                    steps { sh 'docker build -t $IMAGE_FRONTEND ./client' }
                }
                stage('AIOps') {
                    steps { sh 'docker build -t $IMAGE_AIOPS ./aiops' }
                }
            }
        }

        stage('Push Images') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin

                    docker push $IMAGE_BACKEND
                    docker push $IMAGE_FRONTEND
                    docker push $IMAGE_AIOPS
                    '''
                }
            }
        }

        stage('Create Kubernetes Secrets') {
            steps {
                withCredentials([
                    file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE'),
                    string(credentialsId: 'mongodb-uri', variable: 'MONGO_URI'),
                    string(credentialsId: 'jwt-secret', variable: 'JWT_SECRET'),
                    string(credentialsId: 'cloudinary-name', variable: 'CLOUD_NAME'),
                    string(credentialsId: 'cloudinary-api-key', variable: 'CLOUD_KEY'),
                    string(credentialsId: 'cloudinary-api-secret', variable: 'CLOUD_SECRET'),
                    string(credentialsId: 'slack-webhook', variable: 'SLACK_WEBHOOK'),
                    string(credentialsId: 'sns-topic-arn', variable: 'SNS_ARN')
                ]) {
                    sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    kubectl create secret generic quickchat-backend-secret \
                      --from-literal=MONGODB_URI="$MONGO_URI" \
                      --from-literal=JWT_SECRET="$JWT_SECRET" \
                      --dry-run=client -o yaml | kubectl apply -f -

                    kubectl create secret generic quickchat-aiops-secret \
                      --from-literal=SLACK_WEBHOOK="$SLACK_WEBHOOK" \
                      --from-literal=SNS_TOPIC_ARN="$SNS_ARN" \
                      --dry-run=client -o yaml | kubectl apply -f -
                    '''
                }
            }
        }

        stage('Deploy Application') {
            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig',
                    variable: 'KUBECONFIG_FILE'
                )]) {
                    sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    helm upgrade --install quickchat ./helm \
                      --namespace default \
                      --create-namespace \
                      --set backend.tag=$IMAGE_TAG \
                      --set frontend.tag=$IMAGE_TAG \
                      --set aiops.tag=$IMAGE_TAG
                    '''
                }
            }
        }

        stage('Verify Rollout') {
            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig',
                    variable: 'KUBECONFIG_FILE'
                )]) {
                    sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    kubectl rollout status deployment/quickchat-backend
                    kubectl rollout status deployment/quickchat-frontend
                    '''
                }
            }
        }

        //  RUN AIOPS
        stage('Run AIOps') {
            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig',
                    variable: 'KUBECONFIG_FILE'
                )]) {
                    sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE
                    python3 aiops/aiops.py
                    '''
                }
            }
        }
    }

    post {
        always {
            sh '''
            docker container prune -f
            docker image prune -f
            '''
        }
    }
}