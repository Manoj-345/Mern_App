pipeline {
    agent any

    environment {
        IMAGE_TAG = "${env.BUILD_NUMBER}"
        IMAGE_BACKEND  = "manoj232005/quickchat-server:${IMAGE_TAG}"
        IMAGE_FRONTEND = "manoj232005/quickchat-client:${IMAGE_TAG}"
        IMAGE_AIOPS    = "manoj232005/quickchat-aiops:${IMAGE_TAG}"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Manoj-345/Mern_App.git',
                    credentialsId: 'github-creds'
            }
        }

        stage('Build Images') {
            parallel {
                stage('Backend') {
                    steps {
                        sh 'docker build -t $IMAGE_BACKEND ./server'
                    }
                }
                stage('Frontend') {
                    steps {
                        sh 'docker build -t $IMAGE_FRONTEND ./client'
                    }
                }
                stage('AIOps') {
                    steps {
                        sh 'docker build -t $IMAGE_AIOPS ./aiops'
                    }
                }
            }
        }

        stage('Push Images') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    docker push $IMAGE_BACKEND
                    docker push $IMAGE_FRONTEND
                    docker push $IMAGE_AIOPS
                    '''
                }
            }
        }

        stage('Create Kubernetes Secrets') {
            steps {
                withCredentials([
                    file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE'),
                    string(credentialsId: 'mongodb-uri', variable: 'MONGO_URI'),
                    string(credentialsId: 'jwt-secret', variable: 'JWT_SECRET'),
                    string(credentialsId: 'cloudinary-name', variable: 'CLOUD_NAME'),
                    string(credentialsId: 'cloudinary-api-key', variable: 'CLOUD_KEY'),
                    string(credentialsId: 'cloudinary-api-secret', variable: 'CLOUD_SECRET'),
                    string(credentialsId: 'slack-webhook', variable: 'SLACK_WEBHOOK'),
                    string(credentialsId: 'sns-topic-arn', variable: 'SNS_ARN')
                ]) {
                    sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    # Backend Secret
                    kubectl create secret generic quickchat-backend-secret \
                      --from-literal=MONGODB_URI="$MONGO_URI" \
                      --from-literal=JWT_SECRET="$JWT_SECRET" \
                      --from-literal=CLOUDINARY_CLOUD_NAME="$CLOUD_NAME" \
                      --from-literal=CLOUDINARY_API_KEY="$CLOUD_KEY" \
                      --from-literal=CLOUDINARY_API_SECRET="$CLOUD_SECRET" \
                      --dry-run=client -o yaml | kubectl apply -f -

                    # AIOps Secret
                    kubectl create secret generic quickchat-aiops-secret \
                      --from-literal=SLACK_WEBHOOK="$SLACK_WEBHOOK" \
                      --from-literal=SNS_TOPIC_ARN="$SNS_ARN" \
                      --dry-run=client -o yaml | kubectl apply -f -
                    '''
                }
            }
        }

        stage('Deploy Application with Helm') {
            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig',
                    variable: 'KUBECONFIG_FILE'
                )]) {
                    sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    helm upgrade --install quickchat ./helm \
                      --namespace default \
                      --create-namespace \
                      --set backend.tag=$IMAGE_TAG \
                      --set frontend.tag=$IMAGE_TAG \
                      --set aiops.tag=$IMAGE_TAG
                    '''
                }
            }
        }

        stage('Install Prometheus + Grafana + Alertmanager') {
            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig',
                    variable: 'KUBECONFIG_FILE'
                )]) {
                    sh '''
                    export KUBECONFIG=$KUBECONFIG_FILE

                    # Add monitoring repo
                    helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
                    helm repo update

                    # Install full monitoring stack
                    helm upgrade --install monitoring \
                      prometheus-community/kube-prometheus-stack \
                      --namespace monitoring \
                      --create-namespace \
                      --timeout 20m \
                      --wait
                      --set grafana.resources.requests.memory=128Mi \
                      --set prometheus.resources.requests.memory=256Mi \
                      --set alertmanager.enabled=false
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "🎉 Deployment Successful"
        }
        failure {
            echo "❌ Deployment Failed"
        }
        always {
            sh 'docker system prune -f || true'
        }
    }
}